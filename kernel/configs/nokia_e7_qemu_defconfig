# Minimal kernel config for Nokia E7 QEMU (Phase 1)
# Start from omap2plus_defconfig, override to minimal

# Core
CONFIG_ARCH_OMAP3=y
CONFIG_SOC_OMAP3430=y
CONFIG_MACH_OMAP_GENERIC=y

# CPU
CONFIG_CPU_V7=y
CONFIG_ARM_THUMB=y
CONFIG_AEABI=y
CONFIG_NEON=y
CONFIG_VFP=y
CONFIG_VFPv3=y

# Boot
CONFIG_ATAGS=y
CONFIG_USE_OF=y
CONFIG_ARM_APPENDED_DTB=y
CONFIG_ARM_ATAG_DTB_COMPAT=y
CONFIG_ZBOOT_ROM_TEXT=0x0
CONFIG_ZBOOT_ROM_BSS=0x0

# Serial console
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_SERIAL_OF_PLATFORM=y

# Timer
CONFIG_OMAP_32K_TIMER=y

# INTC
CONFIG_OMAP3_IRQ=y

# Minimal
CONFIG_PRINTK=y
CONFIG_BUG=y
CONFIG_EARLY_PRINTK=y
CONFIG_DEBUG_LL=y
