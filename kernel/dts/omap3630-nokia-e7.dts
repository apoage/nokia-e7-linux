// SPDX-License-Identifier: GPL-2.0-only
/*
 * Nokia E7-00 (RM-626) — OMAP3630 + TWL5031 + BCM2727
 *
 * Board revision: 3EQ_08 (schematic), 3EQ_07 (board photo)
 * Schematic: v1.0, 2010-11-18
 *
 * Sources:
 *   - Service schematics (15 pages, vector PDF)
 *   - Firmware RE: rofs.img (514k strings), rofs2.img (616k strings)
 *   - NLoader disassembly (2012-07-27 build)
 *   - Knowledge graph: docs/knowledge-graph/ (9 JSON + 4 Mermaid)
 *   - Block diagram reconstruction from schematic
 *   - Nokia N950/N9 DTS (sister devices, same TWL5031 + OMAP3630)
 *
 * I2C bus mapping (Option A — N950 pattern: PMIC on I2C1):
 *   Nokia I2C_2 → OMAP I2C1 (&i2c1) 0x48070000 = TWL5031 + charger + LED + TPA6130A2
 *   Nokia I2C_1 → OMAP I2C2 (&i2c2) 0x48072000 = GPS module
 *   Nokia I2C_0 → OMAP I2C3 (&i2c3) 0x48060000 = sensors + touch + NFC + keyboard
 *
 * Rationale: N950/N9 DTS places TWL5031 on &i2c1. Nokia numbering (I2C_0/1/2)
 * does NOT map linearly to OMAP I2C1/2/3. Schematic shows PEARL on Nokia "I2C_2",
 * NLoader confirms charger on Nokia "bus 2" (same bus as PEARL).
 * Service manual agent's claim of "I2C_1" for PMIC was a CBUS misread.
 * MUST verify with i2cdetect on real hardware (Task 025 P2).
 *
 * Pad mux: GENIO_INIT partition is BB5-encrypted. Pad mux register values
 * are unknown until UART boot log capture (Task 025 P1). Pinctrl nodes
 * cannot be populated until then.
 */

/dts-v1/;

#include <dt-bindings/input/input.h>
#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/interrupt-controller/irq.h>
#include <dt-bindings/leds/common.h>
#include "omap36xx.dtsi"

/ {
	model = "Nokia E7-00";
	compatible = "nokia,rm626", "ti,omap3630", "ti,omap36xx", "ti,omap3";

	cpus {
		cpu@0 {
			cpu0-supply = <&vcc>;
		};
	};

	chosen {
		bootargs = "console=ttyS0,115200n8 earlycon earlyprintk";
		stdout-path = &uart3;
	};

	memory@80000000 {
		device_type = "memory";
		reg = <0x80000000 0x10000000>; /* 256 MB LPDDR (Samsung K5W8G1GACK-AL56 PoP) */
	};

	/* ===== QEMU paravirtualized block device ===== */
	virtio_mmio@4e000000 {
		compatible = "virtio,mmio";
		reg = <0x4e000000 0x200>;
		interrupts = <12>;
		interrupt-parent = <&intc>;
	};

	/* ===== GPIO keys ===== */
	/*
	 * Volume and capture keys connect directly to OMAP3630 GPIO.
	 * "genio" = OMAP GPIO (RAPUYAMA is combined SoC package).
	 * Power key goes to TWL5031 PwrOnX pin B10 (handled by twl_pwrbutton).
	 * Hall sensor detects keyboard slide open/close.
	 */
	gpio-keys {
		compatible = "gpio-keys";

		volume-up-key {
			label = "Volume Up";
			linux,code = <KEY_VOLUMEUP>;
			gpios = <&gpio1 2 GPIO_ACTIVE_LOW>; /* GPIO2, pin D10 (S2462) */
		};

		volume-down-key {
			label = "Volume Down";
			linux,code = <KEY_VOLUMEDOWN>;
			gpios = <&gpio3 1 GPIO_ACTIVE_LOW>; /* GPIO65, pin U20 (S2462) */
		};

		camera-capture-key {
			label = "Camera Capture";
			linux,code = <KEY_CAMERA>;
			gpios = <&gpio2 4 GPIO_ACTIVE_LOW>; /* GPIO36, pin S25, via QWERTY flex */
		};

		/*
		 * Hall sensor N1000 on QWERTY flex, magnet in tilt assembly.
		 * Service manual L3/4 confirms: interrupt to RAPU GENIO26.
		 * Detects keyboard slider open/close state.
		 */
		keypad-slide {
			label = "Keypad Slide";
			gpios = <&gpio1 26 GPIO_ACTIVE_LOW>; /* GPIO26, service manual */
			linux,input-type = <EV_SW>;
			linux,code = <SW_KEYPAD_SLIDE>;
			wakeup-source;
		};
	};

	/* ===== External fixed regulators (outside TWL5031) ===== */

	/* N1515: Camera ISP 1.8V — enable controlled by BCM2727 GPIO18 */
	vcam_1v8: regulator-vcam-1v8 {
		compatible = "regulator-fixed";
		regulator-name = "vcam_1v8";
		regulator-min-microvolt = <1800000>;
		regulator-max-microvolt = <1800000>;
	};

	/* N1517: Camera analog 2.8V — enable controlled by BCM2727 GPIO19 */
	vcam_2v8: regulator-vcam-2v8 {
		compatible = "regulator-fixed";
		regulator-name = "vcam_2v8";
		regulator-min-microvolt = <2800000>;
		regulator-max-microvolt = <2800000>;
	};

	/* N3201: Memory subsystem boost (eMMC D2800 core + combo D3000) */
	vmem2: regulator-vmem2 {
		compatible = "regulator-fixed";
		regulator-name = "vmem2";
		regulator-min-microvolt = <1800000>;
		regulator-max-microvolt = <1800000>;
		gpio = <&gpio2 27 GPIO_ACTIVE_HIGH>; /* GPIO59, genio59 */
		enable-active-high;
		regulator-boot-on;
		regulator-always-on;
	};

	/*
	 * WLAN power enable — on N950 this is GPIO35; E7 schematic shows
	 * GPIO35 in BTFM/WLAN/GPS area near BOB module. Needs HW verification.
	 */
	vwlan_fixed: regulator-vwlan {
		compatible = "regulator-fixed";
		regulator-name = "vwlan";
		gpio = <&gpio2 3 GPIO_ACTIVE_HIGH>; /* GPIO35, probable WLANENABLE */
		enable-active-high;
	};

	/* WL1273 38.4 MHz reference clock (controlled by wl1271 driver) */
	vctcxo: vctcxo {
		compatible = "fixed-clock";
		#clock-cells = <0>;
		clock-frequency = <38400000>;
	};
};

/* =====================================================================
 * I2C1 — Nokia I2C_2 → OMAP I2C1: PMIC + charger + LED + headphone amp
 * 400 kHz. TWL5031 on I2C1 matches N950/N9 DTS pattern.
 * Schematic shows PEARL on Nokia "I2C_2"; NLoader confirms charger on "bus 2".
 * Nokia I2C_2 → OMAP I2C1 (standard TWL4030-family placement).
 * ===================================================================== */
&i2c1 {
	clock-frequency = <400000>;

	/*
	 * TWL5031/TPS65950 PMIC "PEARL" (N2200, schematic p5-6)
	 * 4 I2C sub-addresses: 0x48 (power), 0x49 (audio), 0x4A (USB/GPIO), 0x4B (PIH)
	 * Built-in: audio codec, vibra H-bridge, LED PWM, SIM interface, RTC
	 * SmartReflex for VCORE domain
	 */
	twl: twl@48 {
		reg = <0x48>;
		interrupts = <7>; /* SYS_NIRQ cascaded to intc */
		interrupt-parent = <&intc>;
	};

	/*
	 * Li-Ion charger IC at 0x6B (schematic p5, NLoader confirmed bus 2)
	 * Only ONE of three variants populated per board:
	 *   BQ2415x: revision_reg >> 5 == 2
	 *   SMB338:  revision_reg bit 4 set
	 *   SMB138:  revision_reg bit 4 clear (and not BQ2415x)
	 * NLoader probes 8-bit addr 0xD6 (= 7-bit 0x6B), reads rev reg to identify.
	 * Same Nokia "I2C_2" bus as PEARL — both map to OMAP I2C1.
	 */
	charger_ic: charger@6b {
		compatible = "ti,bq24150";
		reg = <0x6b>;
		ti,current-limit = <500>;               /* 500mA USB host */
		ti,weak-battery-voltage = <3400>;        /* 3.4V weak threshold */
		ti,battery-regulation-voltage = <4200>;  /* 4.2V Li-Ion */
		ti,charge-current = <550>;               /* 550mA (safe default) */
		ti,termination-current = <50>;           /* 50mA termination */
		ti,resistor-sense = <68>;                /* 68 mOhm — VERIFY on real HW */
	};

	/*
	 * LP5521 LED controller "NJOY-3" (N2500, schematic p9)
	 * Service manual: addr 0110011x = 0x33 (7-bit).
	 * On UI flex. CLK_32K from SleepClkBuf (N2800).
	 *
	 * DCP factory config maps 5 logical channels:
	 *   HOME=ch2, QWERTY=ch3, CHARGINGN=ch4, CHARGINGG=ch5, TORCH=ch6
	 * LP5521 has only 3 physical outputs (R/G/B) — Nokia likely uses
	 * channels 2-4 for the 3 LP5521 outputs (HOME, QWERTY, CHARGING).
	 * TORCH (ch6) is a separate flash LED driver (ADPS1653/LM3555).
	 */
	led_driver: led-controller@33 {
		compatible = "national,lp5521";
		reg = <0x33>;
		clock-mode = /bits/ 8 <1>; /* internal clock (32kHz from SleepClkBuf) */
		#address-cells = <1>;
		#size-cells = <0>;

		led@0 {
			reg = <0>;
			color = <LED_COLOR_ID_GREEN>;
			function = LED_FUNCTION_INDICATOR;
			function-enumerator = <0>;
			chan-name = "e7:green:home";
			led-cur = /bits/ 8 <20>;
			max-cur = /bits/ 8 <100>;
		};

		led@1 {
			reg = <1>;
			color = <LED_COLOR_ID_WHITE>;
			function = LED_FUNCTION_KBD_BACKLIGHT;
			chan-name = "e7:white:keyboard";
			led-cur = /bits/ 8 <20>;
			max-cur = /bits/ 8 <100>;
		};

		led@2 {
			reg = <2>;
			color = <LED_COLOR_ID_AMBER>;
			function = LED_FUNCTION_CHARGING;
			chan-name = "e7:amber:charging";
			led-cur = /bits/ 8 <20>;
			max-cur = /bits/ 8 <100>;
		};
	};

	/*
	 * TI TPA6130A2 stereo headphone amplifier (N2000)
	 * DCP self-test 0xD1 confirms silicon rev 0x0010 = TPA6130A2 (not TPA6140).
	 * Service manual confirms on Nokia I2C_2. Receives XEarL/XEarR from PEARL.
	 * Drives HP_OUT_L/R to AV connector pins 4/5.
	 * Datasheet default I2C addr: 0x60.
	 */
	headphone_amp: audio-amplifier@60 {
		compatible = "ti,tpa6130a2";
		reg = <0x60>;
		Vdd-supply = <&vio>;
	};
};

/* =====================================================================
 * I2C2 — Nokia I2C_1 → OMAP I2C2: GPS module
 * 100 kHz, VIO pull-ups. Multi-master capable (GPS can act as I2C master).
 * ===================================================================== */
&i2c2 {
	clock-frequency = <100000>;

	/*
	 * GPS RF module (N6200, schematic p7)
	 * GPS_EN_RESET <- GPIO53 (genio53)
	 * AGPS_CLK_REQ <- GPIO46 (service manual L3/4 confirms GenIO46)
	 * 16.368 MHz TCXO G6200. Dual mode: I2C + UART.
	 * I2C address unknown — needs scan on real hardware.
	 */
};

/* =====================================================================
 * I2C3 — Nokia I2C_0 → OMAP I2C3: sensor bus
 * 400 kHz, VIO pull-ups, shared on QWERTY flex (X1000) + UI flex (X8002)
 * All sensors, touch, NFC, and keyboard IO expander are on this bus.
 * ===================================================================== */
&i2c3 {
	clock-frequency = <400000>;

	/*
	 * ST LIS302DL 3-axis accelerometer #1 (N1103, schematic p4)
	 * SA0=HIGH -> addr 0x1D. On QWERTY flex (J1100/J1106).
	 * AccInt1 -> GPIO12 (genio12, pin T23)
	 * AccInt2 -> GPIO44 (genio44, pin AA11)
	 * Alt BOM: ADI ADXL340 at same address — probe LIS302DL first.
	 */
	lis302dl_1: accelerometer@1d {
		compatible = "st,lis3lv02d";
		reg = <0x1d>;
		Vdd-supply = <&vaux2>;
		Vdd_IO-supply = <&vio>;

		interrupts-extended = <&gpio1 12 IRQ_TYPE_EDGE_FALLING>,
				      <&gpio2 12 IRQ_TYPE_EDGE_FALLING>;

		/* Click detection on INT2, threshold/wakeup on INT1 */
		st,irq1-ff-wu-1;
		st,irq1-ff-wu-2;
		st,irq2-click;

		st,click-single-x;
		st,click-single-y;
		st,click-single-z;
		st,click-threshold-x = <8>;
		st,click-threshold-y = <8>;
		st,click-threshold-z = <10>;
		st,click-time-limit = <9>;
		st,click-latency = <50>;

		st,wakeup-x-hi;
		st,wakeup-y-hi;
		st,wakeup-threshold = <(800/18)>;
		st,wakeup2-z-hi;
		st,wakeup2-threshold = <(1000/18)>;

		st,highpass-cutoff-hz = <2>;
		st,wu-duration-1 = <8>;
		st,wu-duration-2 = <8>;
	};

	/*
	 * ST LIS302DL 3-axis accelerometer #2
	 * SA0=LOW -> addr 0x1C. Confirmed from CenRep key 4010.
	 * Secondary sensor for portrait/landscape detection.
	 * Interrupt GPIOs unknown (may share with #1 or use separate).
	 *
	 * DISABLED: lis3lv02d driver uses global lis3_dev struct and cannot
	 * support multiple instances. Second probe causes duplicate sysfs
	 * entry → deferred probe rollback → NULL deref in regulator_bulk_disable.
	 * See Task 054. Re-enable when driver is fixed for multi-instance.
	 */
	lis302dl_2: accelerometer@1c {
		compatible = "st,lis3lv02d";
		reg = <0x1c>;
		Vdd-supply = <&vaux2>;
		Vdd_IO-supply = <&vio>;
		status = "disabled";
	};

	/*
	 * AKM AK8974 3-axis magnetometer (N1001, schematic p8)
	 * On QWERTY flex. DVDD=VIO 1.8V, AVDD=VDigiMic 1.8V.
	 * CAD0 pin 5: not tied to GND -> likely HIGH -> addr 0x0F.
	 * Alt BOM: AMI305 at 0x0C or 0x0E (different WHOAMI).
	 */
	ak8974: magnetometer@f {
		compatible = "asahi-kasei,ak8974";
		reg = <0x0f>;
		dvdd-supply = <&vio>;
		/* avdd-supply: VDigiMic 1.8V (Nokia-specific TWL rail, not in twl4030.dtsi) */

		/* Service manual L3/4: Genio40 + Genio41 for magnetometer */
		interrupts-extended = <&gpio2 8 IRQ_TYPE_EDGE_RISING>,  /* GPIO40 = DRDY */
				      <&gpio2 9 IRQ_TYPE_EDGE_FALLING>; /* GPIO41 = INT */
	};

	/*
	 * Avago APDS-99xx ALS/proximity sensor (B8000/N8001, schematic p9)
	 * On UI flex. VDD=VAUX1(2.8V). ADDR_SEL0=GND via R2505(0R) -> 0x39.
	 * PROX_INT -> GenIO3 (service manual L3/4 signal-map confirms)
	 * Alt BOM: Citizen (proxima_citizen), Everlight (proxima_everlight)
	 */
	apds99xx: light-sensor@39 {
		compatible = "avago,apds990x";
		reg = <0x39>;
		vdd-supply = <&vaux1>;

		/* Service manual L3/4: GenIO3 = DiPro_Int (proximity) */
		interrupts-extended = <&gpio1 3 IRQ_TYPE_EDGE_FALLING>; /* GPIO3 */
	};

	/*
	 * Atmel mXT capacitive touchscreen (schematic p9)
	 * On UI flex via I2CSDA/I2CSCL. VDD=VAUX1(2.8V).
	 * TOUCH_INT -> GPIO123 (service manual L3/4 confirms GenIO123)
	 * TOUCH_RST <- GPIO122 (service manual L3/4 confirms GenIO122)
	 * TWL5031 is on I2C1 (separate bus), so 0x4A/0x4B are available here.
	 * Using 0x4C as default — needs I2C scan to confirm.
	 */
	touchscreen: touchscreen@4c {
		compatible = "atmel,maxtouch";
		reg = <0x4c>;
		vdda-supply = <&vaux1>;

		/* Service manual L3/4: GenIO123 = Touch INT, GenIO122 = Touch RST */
		interrupts-extended = <&gpio4 27 IRQ_TYPE_EDGE_FALLING>; /* GPIO123 */
		reset-gpios = <&gpio4 26 GPIO_ACTIVE_LOW>; /* GPIO122 */

		/* DCP factory calibration (RM-626_TouchPad.xml):
		 * Native resolution 180x320 (portrait), physical 40.0x71.0mm.
		 * Display is 640x360 landscape — driver must rotate/scale. */
		touchscreen-size-x = <180>;
		touchscreen-size-y = <320>;
		touchscreen-x-mm = <40>;
		touchscreen-y-mm = <71>;
	};

	/*
	 * National Semiconductor LM8320 keypad/GPIO expander (N1002, schematic p8)
	 * On QWERTY flex. VCC=VIO 1.8V.
	 * CONFIRMED from driver audit (Task 021): firmware uses DIOExpHwLM8320ST,
	 * DIOExpHwLM8320NSC, DIOExpHwLM8320Toshiba — three vendor variants.
	 * NOT TCA8418 as initially assumed from N950 precedent.
	 *
	 * 8 rows (KPX0-7) x 11 columns (KPY0-10), switch map S1003-S1051.
	 * IRQN -> SENSORS connector pin 13 -> RAPUYAMA (genio TBD)
	 * RESETN -> SENSORS connector pin 6 -> RAPUYAMA (genio TBD)
	 * Also routes: Hall_sensor_DET (IN9), Digi_mic_data/clk (IN2/IN8).
	 *
	 * I2C address: 0x34 assumed (matches schematic KPX/KPY BGA pad map),
	 * but LM8320 default is 0x3B — needs I2C scan to confirm.
	 *
	 * Linux driver: lm8323 (predecessor, closest mainline match).
	 * Keymap placeholder — actual row/column wiring needs HW testing.
	 */
	keyboard: keyboard@34 {
		compatible = "national,lm8323";
		reg = <0x34>;
		vcc-supply = <&vio>;
		/*
		 * Real HW: GPIO24 (active-low). QEMU: wired directly to
		 * INTC line 30 to bypass GPIO stubs that cause IRQ storms.
		 */
		interrupt-parent = <&intc>;
		interrupts = <35>;
		keypad,num-rows = <8>;
		keypad,num-columns = <11>;

		linux,keymap = <
			/* Row 0: Q W E R T Y U I O P */
			MATRIX_KEY(0x00, 0x00, KEY_Q)
			MATRIX_KEY(0x00, 0x01, KEY_W)
			MATRIX_KEY(0x00, 0x02, KEY_E)
			MATRIX_KEY(0x00, 0x03, KEY_R)
			MATRIX_KEY(0x00, 0x04, KEY_T)
			MATRIX_KEY(0x00, 0x05, KEY_Y)
			MATRIX_KEY(0x00, 0x06, KEY_U)
			MATRIX_KEY(0x00, 0x07, KEY_I)
			MATRIX_KEY(0x00, 0x08, KEY_O)
			MATRIX_KEY(0x00, 0x09, KEY_P)
			/* Row 1: A S D F G H J K L ? */
			MATRIX_KEY(0x01, 0x00, KEY_A)
			MATRIX_KEY(0x01, 0x01, KEY_S)
			MATRIX_KEY(0x01, 0x02, KEY_D)
			MATRIX_KEY(0x01, 0x03, KEY_F)
			MATRIX_KEY(0x01, 0x04, KEY_G)
			MATRIX_KEY(0x01, 0x05, KEY_H)
			MATRIX_KEY(0x01, 0x06, KEY_J)
			MATRIX_KEY(0x01, 0x07, KEY_K)
			MATRIX_KEY(0x01, 0x08, KEY_L)
			MATRIX_KEY(0x01, 0x09, KEY_QUESTION)
			/* Row 2: Z X C V B N M , . */
			MATRIX_KEY(0x02, 0x00, KEY_Z)
			MATRIX_KEY(0x02, 0x01, KEY_X)
			MATRIX_KEY(0x02, 0x02, KEY_C)
			MATRIX_KEY(0x02, 0x03, KEY_V)
			MATRIX_KEY(0x02, 0x04, KEY_B)
			MATRIX_KEY(0x02, 0x05, KEY_N)
			MATRIX_KEY(0x02, 0x06, KEY_M)
			MATRIX_KEY(0x02, 0x07, KEY_COMMA)
			MATRIX_KEY(0x02, 0x08, KEY_DOT)
			/* Row 3+: Fn, Shift, Space, Sym, Ctrl, Enter, Backspace, arrows */
			MATRIX_KEY(0x03, 0x00, KEY_FN)
			MATRIX_KEY(0x03, 0x01, KEY_LEFTSHIFT)
			MATRIX_KEY(0x03, 0x02, KEY_SPACE)
			MATRIX_KEY(0x04, 0x00, KEY_COMPOSE)
			MATRIX_KEY(0x04, 0x01, KEY_LEFTCTRL)
			MATRIX_KEY(0x04, 0x02, KEY_ENTER)
			MATRIX_KEY(0x04, 0x03, KEY_BACKSPACE)
			MATRIX_KEY(0x05, 0x00, KEY_UP)
			MATRIX_KEY(0x05, 0x01, KEY_LEFT)
			MATRIX_KEY(0x05, 0x02, KEY_DOWN)
			MATRIX_KEY(0x05, 0x03, KEY_RIGHT)
		>;
	};

	/*
	 * NXP PN544 NFC controller (schematic p9)
	 * VDD=VIO 1.8V. I2C address 0x28 (ADDR pins = GND, datasheet default).
	 *
	 * Disabled: driver requires enable-gpios and firmware-gpios but
	 * the GPIO pin assignments are not in our schematic extract.
	 * Enable once real HW UART capture identifies VEN + FW_DL pins.
	 */
	nfc: nfc@28 {
		compatible = "nxp,pn544-i2c";
		reg = <0x28>;
		/* enable-gpios = <&gpioX Y GPIO_ACTIVE_HIGH>; */
		/* firmware-gpios = <&gpioX Y GPIO_ACTIVE_HIGH>; */
		status = "disabled";
	};
};

/* ===== TWL5031 PMIC sub-devices ===== */
/include/ "twl4030.dtsi"

&twl {
	compatible = "ti,twl5031";

	twl_power: power {
		compatible = "ti,twl4030-power";
		ti,use_poweroff;
	};

	/* TWL audio codec — E7 has no separate audio codec (unlike N900).
	 * PEARL handles audio internally. IHF amp N2150 and headphone amp
	 * N2000 are external analog amplifiers driven from PEARL audio out. */
	twl_audio: audio {
		compatible = "ti,twl4030-audio";
		ti,enable-vibra = <1>;
	};
};

&twl_gpio {
	ti,pullups = <0x000001>;   /* BIT(0) — same as N950 */
	ti,pulldowns = <0x008106>; /* BIT(1) | BIT(2) | BIT(8) | BIT(15) — same as N950 */
};

/* =====================================================================
 * TWL5031 regulator configuration
 *
 * Power tree (from knowledge-graph/power-tree.json):
 *   Battery: BL-4D 1200mAh 3.7V (X2070) — confirmed by service manual
 *   PEARL provides: 2 SMPS (VCORE, VIO) + LDOs from VBAT
 *
 * Nokia-specific rails not in twl4030.dtsi (need custom driver work):
 *   VOUT     (2.5V) — BCM2727 DAC/IO
 *   VRFC     (1.8V) — RAPUYAMA RF analog
 *   VR1      (2.5V) — headphone amp N2000, audio, AURA B7500 reference
 *   VDigiMic (1.8V) — digital mics B1001/B2101, magnetometer N1001 AVDD
 * ===================================================================== */

/* VDD1 SMPS: CPU core — SmartReflex calibrated at boot */
&vcc {
	regulator-name = "vcore";
	regulator-min-microvolt = <600000>;
	regulator-max-microvolt = <1450000>;
	regulator-always-on;
};

/* VIO SMPS: 1.8V digital IO — powers nearly everything */
&vio {
	regulator-name = "vio";
	regulator-min-microvolt = <1800000>;
	regulator-max-microvolt = <1800000>;
	regulator-always-on;
};

/* VAUX1 LDO: 2.8V — touch, ALS/prox, cameras, keyboard LEDs
 * Knowledge graph says 2.78V measured; 2.8V is nearest TWL step */
&vaux1 {
	regulator-name = "vaux1";
	regulator-min-microvolt = <2800000>;
	regulator-max-microvolt = <2800000>;
};

/* VAUX2 LDO: 2.5V — accelerometers VDD, combo memory reference */
&vaux2 {
	regulator-name = "vaux2";
	regulator-min-microvolt = <2500000>;
	regulator-max-microvolt = <2500000>;
};

/* VSIM LDO: 1.8V or 3.0V selectable for SIM card (Z9700) */
&vsim {
	regulator-name = "vsim";
	regulator-min-microvolt = <1800000>;
	regulator-max-microvolt = <3000000>;
};

&vdac {
	regulator-name = "vdac";
	regulator-min-microvolt = <1800000>;
	regulator-max-microvolt = <1800000>;
};

&vpll1 {
	regulator-name = "vpll1";
	regulator-min-microvolt = <1800000>;
	regulator-max-microvolt = <1800000>;
};

&vpll2 {
	regulator-name = "vpll2";
	regulator-min-microvolt = <1800000>;
	regulator-max-microvolt = <1800000>;
};

&vintana1 {
	regulator-name = "vintana1";
	regulator-min-microvolt = <1500000>;
	regulator-max-microvolt = <1500000>;
};

&vintana2 {
	regulator-name = "vintana2";
	regulator-min-microvolt = <2750000>;
	regulator-max-microvolt = <2750000>;
};

&vintdig {
	regulator-name = "vintdig";
	regulator-min-microvolt = <1500000>;
	regulator-max-microvolt = <1500000>;
};

/* =====================================================================
 * eMMC — Samsung KLAGE8HM-B001 16GB (D2800, schematic p4)
 * MMC2 bus, series resistors R3222(15R) R3223-R3225(33R)
 * Core: VMEM2 (1.8V N3201 boost via GPIO59)
 * IO pads: VIO_eMMC (N3252 level switch, GPIO17+GPIO23 enable)
 *
 * Disabled: needs pad mux (GENIO_INIT) for real HW.
 * ===================================================================== */
&mmc2 {
	status = "disabled";
	vmmc-supply = <&vmem2>;
	bus-width = <4>;
	ti,non-removable;
};

/* =====================================================================
 * Serial
 * ===================================================================== */

/* UART3: kernel console (debug UART, test point TP2009/TP2010) */
&uart3 {
	status = "okay";
};

/*
 * UART2: WL1273 Bluetooth (H4+ protocol, 115200 bps)
 * BT_RESETX <- GPIO48 (genio48), BT_WAKEUP <- GPIO50 (genio50)
 * Host wakeup GPIO unknown — needs driver audit.
 *
 * Disabled until pad mux is known. Enable and add pinctrl for real HW.
 */
&uart2 {
	status = "disabled";

	bluetooth {
		compatible = "ti,wl1271-bluetooth-nokia", "nokia,h4p-bluetooth";
		reset-gpios = <&gpio2 16 GPIO_ACTIVE_LOW>; /* GPIO48 */
		bluetooth-wakeup-gpios = <&gpio2 18 GPIO_ACTIVE_HIGH>; /* GPIO50 */
		clocks = <&vctcxo>;
		clock-names = "sysclk";
	};
};

&uart1 { status = "disabled"; };
&uart4 { status = "disabled"; };

/* =====================================================================
 * WLAN — TI WL1273 on SPI (firmware RE confirms SPI-A: am_spia.cpp strings)
 * NOTE: Service manual L3/4 says "SDIO" — but firmware strings are definitive.
 *
 * SPI-A bus signals from RAPUYAMA to BOB (WL1273):
 *   SPI_CLK:  RAPUYAMA D10 -> BOB E3
 *   SPI_MOSI: RAPUYAMA Y20 -> BOB F4
 *   SPI_MISO: RAPUYAMA P17 -> BOB G4 (68R R2859 series)
 *   SPI_CSX:  RAPUYAMA G9  -> BOB E4
 *
 * WLAN_IRQ = GPIO77 (genio77, BOB J4)
 *
 * The OMAP MCSPI controller assignment depends on pad mux (GENIO_INIT).
 * Using mcspi1 per knowledge graph; needs HW verification.
 * Disabled until pad mux is available.
 * ===================================================================== */
&mcspi1 {
	status = "disabled";

	wlcore: wlcore@0 {
		compatible = "ti,wl1271";
		reg = <0>;
		spi-max-frequency = <48000000>;
		clock-xtal;
		ref-clock-frequency = <38400000>;
		interrupts-extended = <&gpio3 13 IRQ_TYPE_LEVEL_HIGH>; /* GPIO77 */
		vwlan-supply = <&vwlan_fixed>;
	};
};

/* =====================================================================
 * USB OTG — Mentor MUSB controller
 * External ULPI transceiver N3300 on schematic p5
 * DP/DM/VBUS routed to micro-USB connector
 * ===================================================================== */
&usb_otg_hs {
	interface-type = <0>;
	usb-phy = <&usb2_phy>;
	phys = <&usb2_phy>;
	phy-names = "usb2-phy";
	mode = <3>; /* OTG */
	power = <50>;
};

/* ===== Disabled peripherals ===== */
&mmc1 { status = "disabled"; }; /* combo memory D3000 via RAPUYAMA, not OMAP MMC */
&mmc3 { status = "disabled"; };
&bandgap { status = "disabled"; };

/* RNG not directly accessible (same as N950/N9) */
&rng_target { status = "disabled"; };

/* AES — disable for now (not tested) */
&aes1_target { status = "disabled"; };
&aes2_target { status = "disabled"; };
